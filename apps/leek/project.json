{
  "name": "leek",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/leek",
  "tags": ["type:static"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite apps/leek --open"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/leek"],
      "options": {
        "command": "mkdir -p dist/leek && rsync -a --exclude=project.json --exclude=.DS_Store apps/leek/ dist/leek/"
      }
    }
  }
}
