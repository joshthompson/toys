{
  "name": "letter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/letter",
  "tags": [
    "type:static"
  ],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite apps/letter --open"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/letter"
      ],
      "options": {
        "command": "rsync -a --exclude=project.json --exclude=.DS_Store apps/letter/ dist/letter/"
      }
    }
  }
}
