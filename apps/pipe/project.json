{
  "name": "pipe",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/pipe",
  "tags": [
    "type:static"
  ],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite apps/pipe --open"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/pipe"
      ],
      "options": {
        "command": "mkdir -p dist/pipe && rsync -a --exclude=project.json --exclude=.DS_Store apps/pipe/ dist/pipe/"
      }
    }
  }
}
